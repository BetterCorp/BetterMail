<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="using:BetterMail.App"
             xmlns:core="using:BetterMail.Core"
             x:Class="BetterMail.App.SettingsView">
  <UserControl.Resources>
    <app:AppInfo x:Key="SettingsAppInfo" />
  </UserControl.Resources>
  <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
    <Border Padding="24,14" BorderBrush="{DynamicResource BetterMailDividerBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" />
        <Button Grid.Column="1" Classes="command" Content="Close" Command="{Binding CloseSettingsCommand}"
                AutomationProperties.Name="Close settings" />
      </Grid>
    </Border>

    <Border x:Name="SettingsBanner" Grid.Row="1" Height="176" Background="#040F2F"
            AutomationProperties.Name="BetterMail settings banner">
      <Image Source="/Assets/BetterMailSettingsBanner.png" Stretch="Uniform" MaxWidth="1500"
             HorizontalAlignment="Center" AutomationProperties.Name="BetterMail" />
    </Border>

    <Border Grid.Row="2" BorderBrush="{DynamicResource BetterMailDividerBrush}" BorderThickness="0,0,0,1">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <ListBox ItemsSource="{Binding SettingsTabs}" SelectedItem="{Binding SelectedSettingsTab}"
                 SelectionMode="Single" Background="Transparent" BorderThickness="0">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="18,11" />
              <Setter Property="MinWidth" Value="96" />
              <Setter Property="HorizontalContentAlignment" Value="Center" />
              <Setter Property="BorderThickness" Value="0,0,0,2" />
              <Setter Property="BorderBrush" Value="Transparent" />
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Background" Value="{DynamicResource BetterMailSelectionBrush}" />
              <Setter Property="BorderBrush" Value="{DynamicResource BetterMailAccentBrush}" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="app:SettingsTabItem"><TextBlock Text="{Binding Name}" FontWeight="SemiBold" /></DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </ScrollViewer>
    </Border>

    <Grid x:Name="SettingsContent" Grid.Row="3" Margin="28" ClipToBounds="True">
      <ScrollViewer IsVisible="{Binding ShowAppearanceSettings}">
        <StackPanel MaxWidth="920" HorizontalAlignment="Stretch" Spacing="18">
          <TextBlock Text="Appearance" FontSize="22" FontWeight="SemiBold" />
          <Border Classes="settingsCard">
            <StackPanel Spacing="10">
              <TextBlock Text="Theme" FontWeight="SemiBold" />
              <ComboBox ItemsSource="{Binding ThemeModes}" SelectedItem="{Binding SelectedThemeMode}" />
              <TextBlock Text="Accent" FontWeight="SemiBold" />
              <ComboBox ItemsSource="{Binding AccentNames}" SelectedItem="{Binding SelectedAccentName}" />
              <ToggleSwitch Content="Compact message list" IsChecked="{Binding IsCompact}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer IsVisible="{Binding ShowMailSettings}">
        <StackPanel MaxWidth="920" HorizontalAlignment="Stretch" Spacing="18">
          <TextBlock Text="Mail &amp; notifications" FontSize="22" FontWeight="SemiBold" />
          <Border Classes="settingsCard">
            <StackPanel Spacing="9">
              <TextBlock Text="Notifications" FontSize="18" FontWeight="SemiBold" />
              <ToggleSwitch Content="Desktop notifications for new Inbox mail"
                            IsChecked="{Binding DesktopNotificationsEnabled}"
                            AutomationProperties.Name="Desktop notifications for new Inbox mail" />
              <TextBlock Text="Show an operating-system notification when background sync finds new Inbox mail."
                         Opacity="0.62" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Classes="settingsCard">
            <StackPanel Spacing="9">
              <TextBlock Text="Mail sync" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="Download messages from" FontWeight="SemiBold" />
              <ComboBox ItemsSource="{Binding MailSyncRanges}" SelectedItem="{Binding MailSyncRange}"
                        AutomationProperties.Name="Mail sync history" />
              <TextBlock Text="Changing this starts a background sync. Existing local mail is kept."
                         Opacity="0.62" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Classes="settingsCard">
            <StackPanel Spacing="9">
              <TextBlock Text="Message quick actions" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="Choose up to four actions shown at the right of a message when you hover or select it."
                         Opacity="0.62" TextWrapping="Wrap" />
              <ItemsControl ItemsSource="{Binding MailQuickActionSlots}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="app:MailQuickActionSlot">
                    <Grid ColumnDefinitions="90,*" ColumnSpacing="10" Margin="0,3">
                      <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                      <ComboBox Grid.Column="1"
                                ItemsSource="{Binding $parent[UserControl].DataContext.MailQuickActionOptions}"
                                SelectedItem="{Binding SelectedOption}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="app:MailQuickActionOption">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <TextBlock Text="{Binding Icon}" FontFamily="Segoe UI Symbol" Width="20" TextAlignment="Center" />
                              <TextBlock Text="{Binding Label}" />
                            </StackPanel>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
          <Border Classes="settingsCard">
            <StackPanel x:Name="MailStatisticsSection" Spacing="9">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Mail statistics" FontSize="18" FontWeight="SemiBold" />
                <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="70" Height="3"
                             IsVisible="{Binding IsLoadingMailStatistics}" VerticalAlignment="Center" />
              </Grid>
              <TextBlock Text="{Binding MailStatisticsSummary}" Opacity="0.68" TextWrapping="Wrap" />
              <TextBlock Text="Microsoft 365 totals cover the full mailbox; local totals follow the selected sync history."
                         FontSize="11" Opacity="0.58" TextWrapping="Wrap" />
              <ItemsControl ItemsSource="{Binding MailStatistics}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="app:MailboxStatisticsItem">
                    <Border BorderBrush="{DynamicResource BetterMailDividerBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                      <StackPanel Spacing="2">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                          <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Column="1" Text="{Binding MailboxType}" FontSize="11" Opacity="0.6" />
                        </Grid>
                        <TextBlock Text="{Binding Address}" FontSize="11" Opacity="0.62" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding MessageCounts}" Margin="0,3,0,0" />
                        <TextBlock Text="{Binding DetailCounts}" FontSize="11" Opacity="0.62" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer IsVisible="{Binding ShowSignatureSettings}">
        <StackPanel MaxWidth="1120" HorizontalAlignment="Stretch" Spacing="18">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel>
              <TextBlock Text="Signatures" FontSize="22" FontWeight="SemiBold" />
              <TextBlock Text="Create reusable signatures, then choose one for each mailbox and message type."
                         Opacity="0.62" TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="1" Classes="primary" Content="New signature" Command="{Binding NewSignatureCommand}" />
          </Grid>

          <Border Classes="settingsCard" IsVisible="{Binding IsSignatureTemplatePickerOpen}">
            <StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                  <TextBlock Text="Choose a starting point" FontSize="18" FontWeight="SemiBold" />
                  <TextBlock Text="Select a template to see the real signature before using it. Every template stays editable."
                             Opacity="0.62" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Classes="command" Content="Cancel" Command="{Binding CloseSignatureTemplatesCommand}" />
              </Grid>
              <Grid x:Name="SignatureTemplateLayout" ColumnDefinitions="*,420" ColumnSpacing="14">
                <ListBox x:Name="SignatureTemplateList"
                         ItemsSource="{Binding SignatureTemplates}"
                         SelectedItem="{Binding SelectedSignatureTemplate}"
                         Background="Transparent"
                         BorderThickness="0"
                         AutomationProperties.Name="Signature templates">
                  <ListBox.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                  </ListBox.ItemsPanel>
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                      <Setter Property="Width" Value="210" />
                      <Setter Property="Height" Value="92" />
                      <Setter Property="Margin" Value="0,0,8,8" />
                      <Setter Property="Padding" Value="3" />
                      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                  </ListBox.Styles>
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="app:SignatureTemplate">
                      <Grid RowDefinitions="5,*" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                        <Border Background="{Binding Accent}" />
                        <StackPanel Grid.Row="1" Margin="12,9" Spacing="3">
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.62"
                                     TextWrapping="Wrap" MaxLines="2" />
                        </StackPanel>
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <Border x:Name="SignatureTemplatePreviewPanel"
                        Grid.Column="1"
                        BorderBrush="{DynamicResource BetterMailDividerBrush}"
                        BorderThickness="1"
                        Padding="12">
                  <Grid RowDefinitions="Auto,240,Auto" RowSpacing="10">
                    <StackPanel>
                      <TextBlock Text="Live preview" FontWeight="SemiBold" FontSize="15" />
                      <TextBlock Text="{Binding SelectedSignatureTemplate.Name}" FontSize="12" Opacity="0.62" />
                    </StackPanel>
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource BetterMailDividerBrush}"
                            BorderThickness="1"
                            Background="White">
                      <NativeWebView Source="{Binding SelectedSignatureTemplatePreviewUri}"
                                     NavigationStarted="SignaturePreviewNavigationStarted"
                                     AutomationProperties.Name="Selected signature template preview" />
                    </Border>
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                      <TextBlock Text="{Binding SelectedSignatureTemplate.Description}"
                                 VerticalAlignment="Center"
                                 TextWrapping="Wrap"
                                 Opacity="0.62" />
                      <Button Grid.Column="1"
                              Classes="primary"
                              Content="{Binding SelectedSignatureTemplate.Name, StringFormat='Use {0}'}"
                              Command="{Binding CreateSignatureFromTemplateCommand}"
                              AutomationProperties.Name="Use selected signature template" />
                    </Grid>
                  </Grid>
                </Border>
              </Grid>
            </StackPanel>
          </Border>

          <Grid x:Name="SignatureEditorLayout" ColumnDefinitions="240,*" ColumnSpacing="16">
            <Border x:Name="SignatureListPanel" Classes="settingsCard">
              <StackPanel Spacing="8">
                <TextBlock Text="Your signatures" FontSize="16" FontWeight="SemiBold" />
                <ListBox ItemsSource="{Binding Signatures}" SelectedItem="{Binding SelectedSignature}"
                         MinHeight="240" MaxHeight="430">
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem"><Setter Property="HorizontalContentAlignment" Value="Stretch" /></Style>
                  </ListBox.Styles>
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="app:SignatureItem">
                      <Grid ColumnDefinitions="*,Auto" Margin="2,5">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="Built in" FontSize="10" Opacity="0.55" IsVisible="{Binding IsReadOnly}" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>

            <Border x:Name="SignatureEditorPanel" Grid.Column="1" Classes="settingsCard">
              <StackPanel Spacing="9">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBox Text="{Binding SignatureEditorName}" IsReadOnly="{Binding !CanEditSelectedSignature}"
                           PlaceholderText="Signature name" />
                  <TextBlock Grid.Column="1" Text="Read only" VerticalAlignment="Center" Opacity="0.62"
                             IsVisible="{Binding !CanEditSelectedSignature}" />
                </Grid>
                <app:RichHtmlEditor Height="330" Html="{Binding SignatureEditorHtml, Mode=TwoWay}"
                                    IsReadOnly="{Binding !CanEditSelectedSignature}"
                                    Placeholder="Create your signature…" />
                <TextBlock Text="{Binding SignatureEditorError}" Foreground="#D9493D" TextWrapping="Wrap"
                           IsVisible="{Binding HasSignatureEditorError}" />
                <WrapPanel Orientation="Horizontal">
                  <Button Classes="primary" Content="Save" Command="{Binding SaveSignatureCommand}"
                          IsVisible="{Binding HasUnsavedSignatureChanges}" Margin="0,0,6,6" />
                  <Button Classes="command" Content="Discard changes" Command="{Binding ResetSignatureCommand}"
                          IsVisible="{Binding HasUnsavedSignatureChanges}" Margin="0,0,6,6" />
                  <Button Classes="command" Content="Duplicate" Command="{Binding DuplicateSignatureCommand}"
                          IsVisible="{Binding CanManageSavedSignature}" Margin="0,0,6,6" />
                  <Button Content="Delete" Foreground="#D9493D" Command="{Binding DeleteSignatureCommand}"
                          IsVisible="{Binding CanDeleteSelectedSignature}" Margin="0,0,6,6" />
                </WrapPanel>
                <Border Background="#18D9493D"
                        BorderBrush="#D9493D"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="12"
                        IsVisible="{Binding IsConfirmingSignatureDelete}">
                  <StackPanel Spacing="9">
                    <TextBlock Text="{Binding SignatureDeleteText}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Button Classes="command" Content="Cancel" Command="{Binding CancelDeleteSignatureCommand}" />
                      <Button Content="Delete signature"
                              Background="#D9493D"
                              Foreground="White"
                              Command="{Binding ConfirmDeleteSignatureCommand}" />
                    </StackPanel>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </Grid>

          <Border Classes="settingsCard">
            <StackPanel Spacing="10">
              <TextBlock Text="Defaults by mailbox" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="Primary and shared mailboxes can use different signatures for each action."
                         Opacity="0.62" TextWrapping="Wrap" />
              <ItemsControl ItemsSource="{Binding SignatureAccountSettings}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="app:SignatureAccountSettingsItem">
                    <StackPanel Spacing="7" Margin="0,8,0,4">
                      <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="15" />
                      <TextBlock Text="{Binding EmailAddress}" Opacity="0.6" FontSize="11" />
                      <ItemsControl ItemsSource="{Binding Mailboxes}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="app:SenderSettingsItem">
                            <Border BorderBrush="{DynamicResource BetterMailDividerBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                              <StackPanel Spacing="7">
                                <Grid ColumnDefinitions="*,Auto">
                                  <StackPanel>
                                    <TextBlock Text="{Binding Mailbox.Address}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding MailboxType}" FontSize="11" Opacity="0.58" />
                                  </StackPanel>
                                  <Button Grid.Column="1" Classes="command" Content="{Binding DefaultText}"
                                          Command="{Binding $parent[UserControl].DataContext.SetDefaultSenderCommand}"
                                          CommandParameter="{Binding}" />
                                </Grid>
                                <WrapPanel Orientation="Horizontal">
                                  <StackPanel Width="205" Margin="0,0,10,8" Spacing="3">
                                    <TextBlock Text="New mail" FontSize="11" />
                                    <ComboBox ItemsSource="{Binding SignatureChoices}" SelectedItem="{Binding NewMailSignature}">
                                      <ComboBox.ItemTemplate><DataTemplate x:DataType="app:SignatureItem"><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </StackPanel>
                                  <StackPanel Width="205" Margin="0,0,10,8" Spacing="3">
                                    <TextBlock Text="Reply" FontSize="11" />
                                    <ComboBox ItemsSource="{Binding SignatureChoices}" SelectedItem="{Binding ReplySignature}">
                                      <ComboBox.ItemTemplate><DataTemplate x:DataType="app:SignatureItem"><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </StackPanel>
                                  <StackPanel Width="205" Margin="0,0,10,8" Spacing="3">
                                    <TextBlock Text="Reply all" FontSize="11" />
                                    <ComboBox ItemsSource="{Binding SignatureChoices}" SelectedItem="{Binding ReplyAllSignature}">
                                      <ComboBox.ItemTemplate><DataTemplate x:DataType="app:SignatureItem"><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </StackPanel>
                                  <StackPanel Width="205" Margin="0,0,10,8" Spacing="3">
                                    <TextBlock Text="Forward" FontSize="11" />
                                    <ComboBox ItemsSource="{Binding SignatureChoices}" SelectedItem="{Binding ForwardSignature}">
                                      <ComboBox.ItemTemplate><DataTemplate x:DataType="app:SignatureItem"><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </StackPanel>
                                </WrapPanel>
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer IsVisible="{Binding ShowAccountSettings}">
        <StackPanel MaxWidth="920" HorizontalAlignment="Stretch" Spacing="18">
          <TextBlock Text="Accounts" FontSize="22" FontWeight="SemiBold" />
          <Border Classes="settingsCard">
            <StackPanel Spacing="9">
              <ItemsControl ItemsSource="{Binding SettingsAccounts}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="app:AccountSettingsItem">
                    <Border BorderBrush="{DynamicResource BetterMailDividerBrush}" BorderThickness="0,0,0,1" Padding="8,9"
                            AutomationProperties.Name="{Binding EmailAddress, StringFormat='Account {0}'}">
                      <StackPanel Spacing="7">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding EmailAddress}" Opacity="0.62" TextTrimming="CharacterEllipsis" />
                        <WrapPanel Orientation="Horizontal">
                          <Button Classes="command" Content="Re-authenticate"
                                  Command="{Binding $parent[UserControl].DataContext.ReauthenticateAccountCommand}"
                                  CommandParameter="{Binding Account}"
                                  AutomationProperties.Name="{Binding EmailAddress, StringFormat='Re-authenticate {0}'}" />
                          <Button Classes="command" Content="Add shared mailbox"
                                  Command="{Binding $parent[UserControl].DataContext.AddSharedMailboxForAccountCommand}"
                                  CommandParameter="{Binding Account}"
                                  AutomationProperties.Name="{Binding EmailAddress, StringFormat='Add shared mailbox for {0}'}" />
                          <Button Classes="command" Content="Remove"
                                  Command="{Binding $parent[UserControl].DataContext.RequestRemoveAccountCommand}"
                                  CommandParameter="{Binding Account}"
                                  AutomationProperties.Name="{Binding EmailAddress, StringFormat='Remove {0}'}" />
                        </WrapPanel>
                        <ItemsControl ItemsSource="{Binding SharedMailboxes}" IsVisible="{Binding HasSharedMailboxes}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="core:Mailbox">
                              <TextBlock Text="{Binding Address}" Margin="14,2,0,0" Opacity="0.68" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Button Classes="primary" Content="Add Microsoft account" Command="{Binding ConnectCommand}"
                      HorizontalAlignment="Left" AutomationProperties.Name="Add Microsoft account" />
              <Border Background="#18D9493D" BorderBrush="#D9493D" BorderThickness="1" CornerRadius="3"
                      Padding="12" IsVisible="{Binding IsConfirmingAccountRemoval}">
                <StackPanel Spacing="9">
                  <TextBlock Text="{Binding RemovalAccountText}" FontWeight="SemiBold" TextWrapping="Wrap" />
                  <TextBlock Text="This does not delete anything from Microsoft 365." Opacity="0.68" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Classes="command" Content="Cancel" Command="{Binding CancelRemoveAccountCommand}" />
                    <Button Content="Remove account" Background="#D9493D" Foreground="White" Command="{Binding ConfirmRemoveAccountCommand}" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer IsVisible="{Binding ShowAboutSettings}">
        <StackPanel MaxWidth="920" HorizontalAlignment="Stretch" Spacing="18">
          <TextBlock Text="About" FontSize="22" FontWeight="SemiBold" />
          <Border x:Name="AboutSection" Classes="settingsCard" DataContext="{StaticResource SettingsAppInfo}"
                  AutomationProperties.Name="About BetterMail, version information, license, source code, and releases">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
              <Image Source="/Assets/BetterMail.png" Width="72" Height="72" VerticalAlignment="Top" />
              <StackPanel Grid.Column="1" Spacing="5">
                <TextBlock Text="BetterMail" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Version, StringFormat='Version {0}'}" />
                <TextBlock Text="Copyright &#x00A9; 2026 BetterCorp." Opacity="0.72" />
                <TextBlock Text="GNU Affero General Public License v3.0 only (AGPL-3.0-only)" TextWrapping="Wrap" />
                <WrapPanel Margin="0,7,0,0" Orientation="Horizontal">
                  <Button Classes="command" Margin="0,0,6,6" Content="Source code" CommandParameter="{Binding RepositoryUri}"
                          Click="OpenWorkspaceLinkClicked" />
                  <Button Classes="command" Margin="0,0,6,6" Content="Releases" CommandParameter="{Binding ReleasesUri}"
                          Click="OpenWorkspaceLinkClicked" />
                  <Button Classes="command" Margin="0,0,6,6" Content="License" CommandParameter="{Binding LicenseUri}"
                          Click="OpenWorkspaceLinkClicked" />
                  <Button Classes="command" Margin="0,0,6,6" Content="Check for updates" Click="CheckForUpdatesClicked" />
                </WrapPanel>
              </StackPanel>
            </Grid>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
